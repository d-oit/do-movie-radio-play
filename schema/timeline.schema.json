{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://d-oit.dev/movie-radio-play/timeline.schema.json",
  "title": "TimelineOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "file",
    "analysis_sample_rate",
    "frame_ms",
    "segments"
  ],
  "properties": {
    "file": {
      "type": "string"
    },
    "analysis_sample_rate": {
      "type": "integer",
      "minimum": 1
    },
    "frame_ms": {
      "type": "integer",
      "minimum": 1
    },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "start_ms",
          "end_ms",
          "kind",
          "confidence",
          "tags",
          "prompt"
        ],
        "properties": {
          "start_ms": {
            "type": "integer",
            "minimum": 0
          },
          "end_ms": {
            "type": "integer",
            "minimum": 0
          },
          "kind": {
            "type": "string",
            "enum": [
              "speech",
              "non_voice"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "prompt": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}
